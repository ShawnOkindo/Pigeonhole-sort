#include <iostream>
#include <vector>
using namespace std;

int main() {
    //Here we enter the no. of integers we want to sort.
    int n;
    cout << "Enter the number of integers: ";
    cin >> n;

    if (n <= 0) {
        cout << "Sorted list in descending order: " << std::endl;
        cout << "Total comparisons: 0" << std::endl;
        cout << "Total swaps: 0" << std::endl;
        return 0;
    }

    vector<int> arr(n);
    cout << "Enter the " << n << " integers (separated by spaces): ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    // Step 1: Find min and max (this is where comparisons happen)
    int min_val = arr[0];
    int max_val = arr[0];
    long long comparisons = 0;  // I used long long because n can be up to 1.78 million

    for (int i = 1; i < n; i++) {
        comparisons++;  // compare for min
        if (arr[i] < min_val) {
            min_val = arr[i];
        }
        comparisons++;  // compare for max
        if (arr[i] > max_val) {
            max_val = arr[i];
        }
    }

    // Step 2: Create pigeonholes (count array)
    // This is the "pigeonhole" part - each possible value gets a hole
    long long range = (long long)max_val - min_val + 1;
    if (range > 10000000) {  // safety check so it doesn't crash on huge ranges
        cout << "Range too big for memory! Try smaller numbers." << endl;
        return 0;
    }
    std::vector<int> pigeonholes(range, 0);

    // Step 3: Put each number into its pigeonhole (no comparisons here)
    for (int num : arr) {
        pigeonholes[num - min_val]++;
    }

    // Step 4: Build the sorted list in DESCENDING order
    // Start from the highest value and go down - no swaps needed!
    long long swaps = 0;  // zero swaps because we rebuild the array
    int index = 0;
    for (long long i = range - 1; i >= 0; i--) {
        for (int count = 0; count < pigeonholes[i]; count++) {
            arr[index++] = min_val + (int)i;
        }
    }

    // Output the sorted list
    cout << "\nSorted list in descending order: ";
    for (int i = 0; i < n; i++) {
        cout << arr[i];
        if (i < n - 1) cout << " ";
    }
    cout << std::endl;

    // Show the counters
    cout << "Total comparisons: " << comparisons << endl;
    cout << "Total swaps: " << swaps << endl;

    return 0;
}

